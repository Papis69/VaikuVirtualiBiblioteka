{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{# Puslapio pavadinimas su knygos pavadinimu #}
{% block title %}{{ book.title }} – Knygos{% endblock %}

{% block body %}
<section class="section">
    {# Mygtukas „Grįžti į katalogą" #}
    <a href="{{ path('app_books') }}" class="btn btn-outline btn-sm mb-1"><i class="fas fa-arrow-left"></i> Grįžti į katalogą</a>

    {# === KNYGOS DETALIŲ IŠDĖSTYMAS (2 stulpeliai: nuotrauka + informacija) === #}
    <div class="book-detail">
        {# Kairė pusė – knygos viršelis #}
        <div class="book-detail-image" style="background-color: {{ book.category ? book.category.color : '#6C63FF' }}">
            {% if book.coverImage %}
                <img src="{{ book.coverImage }}" alt="{{ book.title }}">
            {% else %}
                <i class="fas fa-book fa-5x"></i>
            {% endif %}
        </div>
        {# Dešinė pusė – knygos informacija #}
        <div class="book-detail-info">
            {# Knygos pavadinimas #}
            <h1>{{ book.title }}</h1>
            {# Autorius #}
            <p class="book-author"><i class="fas fa-user-edit"></i> {{ book.author }}</p>

            {# Kategorijos žymė #}
            {% if book.category %}
                <span class="tag" style="background-color: {{ book.category.color }}">{{ book.category.name }}</span>
            {% endif %}

            {# Amžiaus diapazonas #}
            {% if book.minAge and book.maxAge %}
                <span class="age-badge"><i class="fas fa-child"></i> Amžius: {{ book.minAge }}–{{ book.maxAge }} m.</span>
            {% endif %}

            {# Knygos aprašymas (jei yra) #}
            {% if book.description %}
                <div class="book-description">
                    <h3>Aprašymas</h3>
                    {# nl2br – paverčia naują eilutę į <br> HTML žymę #}
                    <p>{{ book.description|nl2br }}</p>
                </div>
            {% endif %}

            {# Skaitymo mygtukai #}
            {% if book.contentUrl %}
                <div class="book-actions">
                    {# Pagrindinis mygtukas – skaitymo puslapis #}
                    <a href="{{ path('app_book_read', {id: book.id}) }}" class="btn btn-primary btn-lg">
                        <i class="fas fa-book-reader"></i> Skaityti knygą
                    </a>
                    {# Antrinis mygtukas – atidaryti šaltinyje #}
                    <a href="{{ book.contentUrl }}" target="_blank" class="btn btn-outline">
                        <i class="fas fa-external-link-alt"></i> Atidaryti Project Gutenberg
                    </a>
                    {# Pažymėti kaip perskaitytą #}
                    {% if app.user %}
                        {% if isRead %}
                            <span class="btn btn-success btn-lg" style="cursor: default; opacity: 0.9;">
                                <i class="fas fa-check-circle"></i> Perskaityta ✓
                            </span>
                        {% else %}
                            <form method="post" action="{{ path('app_book_mark_read', {id: book.id}) }}" style="margin: 0;">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('mark_read_' ~ book.id) }}">
                                <button type="submit" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-bookmark"></i> Pažymėti kaip perskaitytą
                                </button>
                            </form>
                        {% endif %}
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
