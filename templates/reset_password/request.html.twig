{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}
        <h1><i class="fas fa-envelope"></i> Atkurti slaptažodį</h1>

        {{ form_start(requestForm) }}
            <div class="form-group">
                {{ form_row(requestForm.email, {'attr': {'class': 'form-control', 'placeholder': 'jusu@pastas.lt'}}) }}
            </div>
            
            <div style="margin-bottom: 20px; color: #666; font-size: 0.9em; text-align: center;">
                Įveskite savo el. pašto adresą ir mes atsiųsime nuorodą, su kuria galėsite pasikeisti slaptažodį.
            </div>

            <button class="btn btn-primary btn-block btn-lg">
                <i class="fas fa-paper-plane"></i> Siųsti atkūrimo nuorodą
            </button>
        {{ form_end(requestForm) }}
    </div>
</div>
{% endblock %}
