{# Custom 404 klaidos puslapis #}
{% extends 'base.html.twig' %}

{% block title %}Puslapis nerastas – 404{% endblock %}

{% block body %}
<section class="error-page">
    <div class="error-card">
        {# Iliustracija #}
        <div class="error-illustration">📚🔍</div>
        {# Klaidos kodas su gradientu #}
        <div class="error-code">404</div>
        <h2>Oi! Puslapis nerastas</h2>
        <p>Atrodo, kad ši knyga dingo iš mūsų lentynų... Galbūt ji buvo perkelta arba neegzistuoja.</p>
        {# Grįžimo mygtukai #}
        <div class="hero-buttons">
            <a href="{{ path('app_home') }}" class="btn btn-primary"><i class="fas fa-home"></i> Grįžti į pradžią</a>
            <a href="{{ path('app_books') }}" class="btn btn-secondary"><i class="fas fa-book"></i> Naršyti knygas</a>
        </div>
    </div>
</section>
{% endblock %}
