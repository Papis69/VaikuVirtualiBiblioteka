{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{% block title %}Mano profilis{% endblock %}

{% block body %}
<section class="section">
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-user"></i> Mano profilis</h1>
        <a href="{{ path('app_profile_edit') }}" class="btn btn-secondary"><i class="fas fa-user-edit"></i> Redaguoti profilį</a>
    </div>

    {# === PROFILIO TINKLELIS === #}
    <div class="profile-grid">
        {# === PROFILIO KORTELĖ (gradient fono) === #}
        <div class="profile-card">
            {# Vartotojo avataro ikona #}
            <div class="profile-avatar">
                <i class="fas fa-user-circle fa-5x"></i>
            </div>
            {# Vartotojo vardas #}
            <h2>{{ user.username }}</h2>
            {# El. paštas #}
            <p class="profile-email"><i class="fas fa-envelope"></i> {{ user.email }}</p>
            {# Registracijos data #}
            <p class="profile-date"><i class="fas fa-calendar"></i> Registracija: {{ user.createdAt|date('Y-m-d') }}</p>
            {# Taškų skaičius (didelis, ryškus) #}
            <div class="profile-points">
                <i class="fas fa-star"></i> <span>{{ user.points }}</span> taškų
            </div>
        </div>

        {# === ŽENKLIUKŲ SEKCIJA === #}
        <div class="profile-section">
            <h3><i class="fas fa-medal"></i> Mano ženkliukai ({{ user.userBadges|length }})</h3>
            {% if user.userBadges|length > 0 %}
                {# Ženkliukų tinklelis #}
                <div class="badges-grid">
                    {% for ub in user.userBadges %}
                    <div class="badge-item">
                        {# Ženkliuko ikona (emoji) #}
                        <div class="badge-icon">{{ ub.badge.icon ?? '🏅' }}</div>
                        {# Ženkliuko pavadinimas #}
                        <span>{{ ub.badge.name }}</span>
                        {# Gavimo data #}
                        <small>{{ ub.awardedAt|date('Y-m-d') }}</small>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="empty-state">Ženkliukų dar neturite. Atlikite misijas!</p>
            {% endif %}
        </div>

        {# === MISIJŲ SEKCIJA === #}
        <div class="profile-section">
            <h3><i class="fas fa-tasks"></i> Mano misijos ({{ user.userMissions|length }})</h3>
            {% if user.userMissions|length > 0 %}
                <ul class="profile-list">
                    {% for um in user.userMissions %}
                    <li>
                        {# Statuso ikona pagal būseną #}
                        {% if um.approved %}
                            <i class="fas fa-check-circle text-success"></i>
                        {% elseif um.pending %}
                            <i class="fas fa-hourglass-half text-warning"></i>
                        {% elseif um.rejected %}
                            <i class="fas fa-times-circle" style="color: var(--danger);"></i>
                        {% endif %}
                        {# Misijos pavadinimas #}
                        {{ um.mission.title }}
                        {# Papildoma informacija pagal statusą #}
                        <span class="list-meta">
                            {% if um.approved %}
                                <span class="badge badge-success" style="font-size: 0.75rem;">Patvirtinta</span>
                                +{{ um.mission.rewardPoints }} tšk. | {{ um.completedAt|date('Y-m-d') }}
                            {% elseif um.pending %}
                                <span class="badge badge-warning" style="font-size: 0.75rem;">Laukia</span>
                            {% elseif um.rejected %}
                                <span class="badge badge-danger" style="font-size: 0.75rem;">Atmesta</span>
                                {% if um.rejectionReason %}
                                    — {{ um.rejectionReason }}
                                {% endif %}
                            {% endif %}
                        </span>
                    </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="empty-state">Misijų dar neatlikote.</p>
            {% endif %}
        </div>

        {# === PRIZŲ SEKCIJA === #}
        <div class="profile-section">
            <h3><i class="fas fa-gift"></i> Įsigyti prizai ({{ user.userRewards|length }})</h3>
            {% if user.userRewards|length > 0 %}
                <ul class="profile-list">
                    {% for ur in user.userRewards %}
                    <li>
                        <i class="fas fa-gift text-primary"></i>
                        {# Prizo pavadinimas #}
                        {{ ur.reward.name }}
                        {# Įsigijimo data #}
                        <span class="list-meta">{{ ur.claimedAt|date('Y-m-d') }}</span>
                    </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="empty-state">Prizų dar neįsigijote.</p>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
