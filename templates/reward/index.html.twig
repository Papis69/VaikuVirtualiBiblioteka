{% extends 'base.html.twig' %}

{% block title %}Prizai{% endblock %}

{% block body %}
<section class="section">
    <h1 class="page-title"><i class="fas fa-gift"></i> Prizų parduotuvė</h1>
    <p class="section-subtitle">Iškeisk sukauptus taškus į prizus!</p>

    {% if app.user %}
        <div class="points-display">
            <i class="fas fa-star"></i> Jūsų taškai: <strong>{{ app.user.points }}</strong>
        </div>
    {% endif %}

    <div class="card-grid">
        {% for reward in rewards %}
        <div class="card reward-card">
            <div class="card-image reward-image">
                {% if reward.image %}
                    <img src="{{ reward.image }}" alt="{{ reward.name }}">
                {% else %}
                    <i class="fas fa-gift fa-3x"></i>
                {% endif %}
            </div>
            <div class="card-body">
                <h3>{{ reward.name }}</h3>
                <p>{{ reward.description }}</p>
                <div class="reward-cost">
                    <i class="fas fa-coins"></i> {{ reward.costInPoints }} taškų
                </div>
                <div class="reward-stock">
                    <i class="fas fa-box"></i> Likutis: {{ reward.stock }}
                </div>

                {% if app.user %}
                    {% if app.user.points >= reward.costInPoints and reward.stock > 0 %}
                        <a href="{{ path('app_reward_claim', {id: reward.id}) }}" class="btn btn-primary btn-block"
                           onclick="return confirm('Ar tikrai norite įsigyti šį prizą už {{ reward.costInPoints }} taškų?')">
                            <i class="fas fa-shopping-cart"></i> Įsigyti
                        </a>
                    {% elseif reward.stock <= 0 %}
                        <button class="btn btn-disabled btn-block" disabled><i class="fas fa-times-circle"></i> Išparduota</button>
                    {% else %}
                        <button class="btn btn-disabled btn-block" disabled><i class="fas fa-lock"></i> Trūksta taškų</button>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-outline btn-block">
                        <i class="fas fa-sign-in-alt"></i> Prisijunkite
                    </a>
                {% endif %}
            </div>
        </div>
        {% else %}
            <p class="empty-state"><i class="fas fa-inbox"></i> Prizų dar nėra.</p>
        {% endfor %}
    </div>
</section>
{% endblock %}
