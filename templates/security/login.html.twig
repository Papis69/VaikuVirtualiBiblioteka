{% extends 'base.html.twig' %}

{% block title %}Prisijungimas{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        <h1><i class="fas fa-sign-in-alt"></i> Prisijungimas</h1>

        {% if error %}
            <div class="alert alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div class="form-group">
                <label for="inputEmail"><i class="fas fa-envelope"></i> El. paštas</label>
                <input type="email" id="inputEmail" name="_username" value="{{ last_username }}" class="form-control" required autofocus placeholder="jusu@pastas.lt">
            </div>
            <div class="form-group">
                <label for="inputPassword"><i class="fas fa-lock"></i> Slaptažodis</label>
                <input type="password" id="inputPassword" name="_password" class="form-control" required placeholder="••••••">
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="checkbox-label">
                    <input type="checkbox" name="_remember_me"> Prisiminti mane
                </label>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">
                <i class="fas fa-sign-in-alt"></i> Prisijungti
            </button>
        </form>

        <p class="auth-link">Neturite paskyros? <a href="{{ path('app_register') }}">Registruotis</a></p>
    </div>
</div>
{% endblock %}
