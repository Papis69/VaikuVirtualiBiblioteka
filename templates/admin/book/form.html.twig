{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{# Dinaminis pavadinimas (iš kontrolerio: 'Nauja knyga' arba 'Redaguoti knygą') #}
{% block title %}{{ title }}{% endblock %}

{% block body %}
<section class="section">
    {# Grįžimo mygtukas #}
    <a href="{{ path('admin_books') }}" class="btn btn-outline btn-sm mb-1"><i class="fas fa-arrow-left"></i> Grįžti</a>
    {# Puslapio antraštė (dinaminis iš kontrolerio) #}
    <h1 class="page-title">{{ title }}</h1>

    <div class="form-card">
        {# Pradedame Symfony formos atvaizdavimą #}
        {{ form_start(form) }}
            {# Kiekvienas form_widget atvaizduoja HTML input elementą #}
            <div class="form-group">{{ form_label(form.title) }}{{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.title) }}</div>
            <div class="form-group">{{ form_label(form.author) }}{{ form_widget(form.author, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.author) }}</div>
            <div class="form-group">{{ form_label(form.description) }}{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}{{ form_errors(form.description) }}</div>
            <div class="form-group">{{ form_label(form.category) }}{{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.category) }}</div>
            {# Amžiaus laukai vienoje eilutėje (form-row) #}
            <div class="form-row">
                <div class="form-group half">{{ form_label(form.minAge) }}{{ form_widget(form.minAge, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group half">{{ form_label(form.maxAge) }}{{ form_widget(form.maxAge, {'attr': {'class': 'form-control'}}) }}</div>
            </div>
            <div class="form-group">{{ form_label(form.coverImage) }}{{ form_widget(form.coverImage, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_label(form.contentUrl) }}{{ form_widget(form.contentUrl, {'attr': {'class': 'form-control'}}) }}</div>
            {# Išsaugojimo mygtukas #}
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Išsaugoti</button>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}
