{% extends 'base.html.twig' %}

{% block title %}Admin – Knygos{% endblock %}

{% block body %}
<section class="section">
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-book"></i> Knygų valdymas</h1>
        <a href="{{ path('admin_book_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Nauja knyga</a>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pavadinimas</th>
                    <th>Autorius</th>
                    <th>Kategorija</th>
                    <th>Amžius</th>
                    <th>Veiksmai</th>
                </tr>
            </thead>
            <tbody>
                {% for book in books %}
                <tr>
                    <td>{{ book.id }}</td>
                    <td>{{ book.title }}</td>
                    <td>{{ book.author }}</td>
                    <td>{{ book.category ? book.category.name : '–' }}</td>
                    <td>{{ book.minAge ?? '–' }}–{{ book.maxAge ?? '–' }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_book_edit', {id: book.id}) }}" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                        <a href="{{ path('admin_book_delete', {id: book.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Ar tikrai norite ištrinti?')"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="empty-state">Knygų nėra</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
