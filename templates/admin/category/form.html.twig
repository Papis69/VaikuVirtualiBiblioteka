{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<section class="section">
    <a href="{{ path('admin_categories') }}" class="btn btn-outline btn-sm mb-1"><i class="fas fa-arrow-left"></i> Grįžti</a>
    <h1 class="page-title">{{ title }}</h1>

    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-group">{{ form_label(form.name) }}{{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.name) }}</div>
            <div class="form-group">{{ form_label(form.color) }}{{ form_widget(form.color, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.color) }}</div>
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Išsaugoti</button>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}
