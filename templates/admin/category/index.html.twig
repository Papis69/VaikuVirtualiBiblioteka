{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{% block title %}Admin – Kategorijos{% endblock %}

{% block body %}
<section class="section">
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-palette"></i> Kategorijų valdymas</h1>
        <a href="{{ path('admin_category_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Nauja kategorija</a>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Spalva</th>
                    <th>Pavadinimas</th>
                    <th>Knygų sk.</th>
                    <th>Veiksmai</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                <tr>
                    <td>{{ category.id }}</td>
                    <td>
                        <span style="display: inline-block; width: 24px; height: 24px; border-radius: 6px; background: {{ category.color ?? '#ccc' }}; vertical-align: middle;"></span>
                        <code style="margin-left: 6px; font-size: 0.85rem;">{{ category.color ?? '–' }}</code>
                    </td>
                    <td><strong>{{ category.name }}</strong></td>
                    <td>{{ category.books|length }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_category_edit', {id: category.id}) }}" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                        <a href="{{ path('admin_category_delete', {id: category.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Ar tikrai norite ištrinti šią kategoriją?')"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="empty-state">Kategorijų nėra</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
