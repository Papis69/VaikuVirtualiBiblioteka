{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<section class="section">
    <a href="{{ path('admin_rewards') }}" class="btn btn-outline btn-sm mb-1"><i class="fas fa-arrow-left"></i> Grįžti</a>
    <h1 class="page-title">{{ title }}</h1>

    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-group">{{ form_label(form.name) }}{{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.name) }}</div>
            <div class="form-group">{{ form_label(form.description) }}{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}{{ form_errors(form.description) }}</div>
            <div class="form-group">{{ form_label(form.image) }}{{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}{{ form_errors(form.image) }}</div>
            <div class="form-row">
                <div class="form-group half">{{ form_label(form.costInPoints) }}{{ form_widget(form.costInPoints, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group half">{{ form_label(form.stock) }}{{ form_widget(form.stock, {'attr': {'class': 'form-control'}}) }}</div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Išsaugoti</button>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}
