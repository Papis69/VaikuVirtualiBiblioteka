{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{% block title %}Admin – Prizai{% endblock %}

{% block body %}
<section class="section">
    {# Antraštė su „Naujas prizas" mygtuku #}
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-gift"></i> Prizų valdymas</h1>
        <a href="{{ path('admin_reward_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Naujas prizas</a>
    </div>

    {# Prizų lentelė #}
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pavadinimas</th>
                    <th>Kaina (tšk.)</th>
                    <th>Likutis</th>
                    <th>Veiksmai</th>
                </tr>
            </thead>
            <tbody>
                {% for reward in rewards %}
                <tr>
                    <td>{{ reward.id }}</td>
                    <td>{{ reward.name }}</td>
                    <td><i class="fas fa-coins"></i> {{ reward.costInPoints }}</td>
                    <td>{{ reward.stock }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_reward_edit', {id: reward.id}) }}" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                        <a href="{{ path('admin_reward_delete', {id: reward.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Ar tikrai?')"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="empty-state">Prizų nėra</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
