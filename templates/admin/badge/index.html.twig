{# Paveldime bazinį šabloną #}
{% extends 'base.html.twig' %}

{% block title %}Admin – Ženkliukai{% endblock %}

{% block body %}
<section class="section">
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-medal"></i> Ženkliukų valdymas</h1>
        <a href="{{ path('admin_badge_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Naujas ženkliukas</a>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ikona</th>
                    <th>Pavadinimas</th>
                    <th>Aprašymas</th>
                    <th>Reik. taškai</th>
                    <th>Veiksmai</th>
                </tr>
            </thead>
            <tbody>
                {% for badge in badges %}
                <tr>
                    <td>{{ badge.id }}</td>
                    <td style="font-size: 1.5rem;">{{ badge.icon ?? '🏅' }}</td>
                    <td><strong>{{ badge.name }}</strong></td>
                    <td>{{ badge.description ?? '–' }}</td>
                    <td><i class="fas fa-star text-warning"></i> {{ badge.requiredPoints }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_badge_edit', {id: badge.id}) }}" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                        <a href="{{ path('admin_badge_delete', {id: badge.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Ar tikrai norite ištrinti šį ženkliuką?')"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="empty-state">Ženkliukų nėra</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
