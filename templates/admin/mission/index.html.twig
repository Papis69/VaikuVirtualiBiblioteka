{% extends 'base.html.twig' %}

{% block title %}Admin – Misijos{% endblock %}

{% block body %}
<section class="section">
    <div class="section-header">
        <h1 class="page-title"><i class="fas fa-flag"></i> Misijų valdymas</h1>
        <a href="{{ path('admin_mission_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Nauja misija</a>
    </div>

    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Pavadinimas</th>
                    <th>Tipas</th>
                    <th>Taškai</th>
                    <th>Veiksmai</th>
                </tr>
            </thead>
            <tbody>
                {% for mission in missions %}
                <tr>
                    <td>{{ mission.id }}</td>
                    <td>{{ mission.title }}</td>
                    <td>{{ mission.type ?? '–' }}</td>
                    <td><i class="fas fa-coins"></i> {{ mission.rewardPoints }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_mission_edit', {id: mission.id}) }}" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                        <a href="{{ path('admin_mission_delete', {id: mission.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Ar tikrai?')"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="empty-state">Misijų nėra</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
